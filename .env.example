APP_ENV=production
DEBUG=False

# Gemini API key from Google AI Studio:
# https://aistudio.google.com/app/apikey
# Keep real keys only in .env. Never commit actual API keys.
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_API_KEY=your-gemini-api-key

# Gemini chat LLM
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_VERSION=v1
GEMINI_GENERATION_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=180

# Gemini embeddings
EMBEDDING_PROVIDER=gemini
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_API_VERSION=v1beta
GEMINI_EMBEDDING_BATCH_SIZE=8
GEMINI_EMBEDDING_BATCH_DELAY_SECONDS=2
GEMINI_EMBEDDING_MAX_RETRIES=6

# Chroma and upload storage
CHROMA_PERSIST_DIR=./data/vectorstore
UPLOAD_DIR=./data/uploads
CHROMA_COLLECTION_NAME=documents

# Document processing
MAX_FILE_SIZE_MB=10
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K_RESULTS=3
MAX_GRAPH_RETRIES=3

# Optional Ollama fallback. Only required when LLM_PROVIDER=ollama or EMBEDDING_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
